{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "Launch Chrome (Webpack Dev Server)",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "trace": true,
      "sourceMapPathOverrides": {
        "webpack:///./*": "${webRoot}/*",
        "webpack:///*": "${webRoot}/*",
        "webpack:///src/*": "${webRoot}/src/*",
        "webpack:///./src/*": "${webRoot}/src/*",
        "webpack:///node_modules/*": "${webRoot}/node_modules/*",
        "webpack:///GuiltMeterWebPackV1/*": "${webRoot}/*"
      }
    },
    {
      "type": "msedge",
      "request": "launch",
      "name": "Launch Edge (Webpack Dev Server)",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}",
      "sourceMaps": true,
      "trace": true,
      "sourceMapPathOverrides": {
        "webpack:///./*": "${webRoot}/*",
        "webpack:///*": "${webRoot}/*",
        "webpack:///src/*": "${webRoot}/src/*",
        "webpack:///./src/*": "${webRoot}/src/*",
        "webpack:///node_modules/*": "${webRoot}/node_modules/*",
        "webpack:///GuiltMeterWebPackV1/*": "${webRoot}/*"
      }
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Debug Jest Tests",
      "program": "${workspaceFolder}/node_modules/jest/bin/jest.js",
      "args": [
        "--runInBand",
        "--watchAll=false"
      ],
      "console": "integratedTerminal",
      "internalConsoleOptions": "neverOpen"
    }
  ],
  "compounds": [
    {
      "name": "Start Dev Server + Debug Chrome",
      "configurations": [
        "Launch Chrome (Webpack Dev Server)"
      ],
      "preLaunchTask": "Start Webpack Dev Server"
    },
    {
      "name": "Start Dev Server + Debug Edge",
      "configurations": [
        "Launch Edge (Webpack Dev Server)"
      ],
      "preLaunchTask": "Start Webpack Dev Server"
    }
  ]
}