{
  "name": "GuiltMeterWebPackV1",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "dev": "webpack serve --mode development",
    "start": "webpack serve --mode development",
    "build:dev": "npm run clean && webpack --mode development",
    "build": "npm run build:prod",
    "build:prod": "npm run clean && webpack --mode production --env minify=true",
    "build:min": "npm run clean && webpack --mode production --env minify=true",
    "build:nonmin": "npm run clean && webpack --mode production --env minify=false",
    "build:nonmin:dev": "npm run clean && webpack --mode development --env minify=false",
    "deploybuild": "npm run build:nonmin && npx del-cli dist/**/*.map",
    "lint": "eslint \"src/**/*.js\"",
    "lint:fix": "npx eslint \"src/**/*.js\" --fix",
    "analyze": "npm run clean && webpack --mode production --env analyze",
    "format": "prettier --write \"src/**/*.{js,jsx,scss,css,html}\"",
    "clean": "rimraf dist",
    "clean:verify": "node -e \"console.log('Dist exists:', require('fs').existsSync('dist'))\"",
    "preview": "npm run build && npx serve dist",
    "test:build": "npm run clean && npm run build && npm run clean:verify",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build:webdev": "npm run clean && webpack --mode development",
    "build:webprod": "npm run clean && webpack --mode production",
    "serve:webdev": "npm run clean && webpack serve --mode development",
    "serve:webprod": "npm run clean && webpack serve --mode production"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Guilt Meter is a modern, interactive web application that is using experimental LLM coding features for development.",
  "dependencies": {
    "@fortawesome/fontawesome-free": "^6.7.2",
    "@popperjs/core": "^2.11.8",
    "@webpack-cli/serve": "^2.0.5",
    "bootstrap": "^5.3.6",
    "chart.js": "^4.5.0",
    "d3": "^7.9.0",
    "decimal.js": "^10.5.0",
    "jquery": "^3.7.1",
    "webpack-bundle-analyzer": "^4.10.2"
  },
  "devDependencies": {
    "@babel/core": "^7.27.7",
    "@babel/preset-env": "^7.27.2",
    "babel-loader": "^10.0.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.2",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "del-cli": "^6.0.0",
    "eslint": "^9.29.0",
    "glob-all": "^3.3.1",
    "html-webpack-plugin": "^5.6.3",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jsdom": "^24.0.0",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss": "^8.4.0",
    "postcss-loader": "^8.0.0",
    "prettier": "^3.5.3",
    "purgecss-webpack-plugin": "^5.0.0",
    "rimraf": "^6.0.0",
    "sass": "^1.89.2",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "terser-webpack-plugin": "^5.3.14",
    "uuid": "^14.0.1",
    "webpack": "^5.99.9",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^5.2.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RonGarlit/GuiltMeterWebPackV1_Project.git"
  }
}
